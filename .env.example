# Neon PostgreSQL（从 https://neon.tech 控制台复制连接串）
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# 会话签名密钥（任意 32+ 字符随机字符串）
SESSION_SECRET=your-random-secret-at-least-32-characters-long

# Vercel AI Gateway（https://vercel.com/ai-gateway 创建 API Key）
AI_GATEWAY_API_KEY=

# 可选：模型 ID，默认 openai/gpt-4o-mini
# AI_MODEL=openai/gpt-4o-mini

# 可选：注入笔记上下文的上限
# AI_MAX_CONTEXT_CHARS=12000
# AI_MAX_NOTES=30
